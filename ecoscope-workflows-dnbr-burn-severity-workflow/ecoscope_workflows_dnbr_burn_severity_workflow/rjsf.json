    "aoi_name": {
      "additionalProperties": false,
      "properties": {
        "group_name": {
          "title": "Area of Interest",
          "type": "string",
          "description": "EarthRanger spatial features group that defines the area to map for burn severity (e.g. 'Reserve Boundary', 'North Block'). Find it in ER under Admin \u2192 Map Layers \u2192 Feature Groups. Severity is computed within this boundary.",
          "ecoscope:transform": [
            {
              "transformer": "EarthRangerEnumResolver",
              "transformer_kws": {
                "type": "spatial_feature_group",
                "depends_on": "properties.er_connection.properties.data_source.properties.name"
              }
            }
          ]
        }
      },
      "required": [
        "group_name"
      ],
      "type": "object",
      "title": "Area of Interest"
    },
    "overlay_name": {
      "additionalProperties": false,
      "properties": {
        "group_name": {
          "default": "",
          "title": "Overlay Layer (optional)",
          "type": "string",
          "description": "Optional EarthRanger spatial features group to draw on top of the map (e.g. 'Roads', 'Fencelines', 'Water Sources'). Leave blank for none.",
          "ecoscope:transform": [
            {
              "transformer": "EarthRangerEnumResolver",
              "transformer_kws": {
                "type": "spatial_feature_group",
                "depends_on": "properties.er_connection.properties.data_source.properties.name"
              }
            }
          ]
        }
      },
      "type": "object",
      "required": [],
      "title": "Overlay Layer Group Name"
    },
